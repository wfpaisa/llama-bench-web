{
  "name": "plane-llama-bench",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "gen:version": "node scripts/generate-version.mjs",
    "start": "bun run gen:version && ng serve",
    "build": "bun run gen:version && ng build",
    "watch": "bun run gen:version && ng build --watch --configuration development"
  },
  "private": true,
  "packageManager": "bun@1.3.14",
  "dependencies": {
    "@angular/common": "^22.0.6",
    "@angular/compiler": "^22.0.6",
    "@angular/core": "^22.0.6",
    "@angular/forms": "^22.0.6",
    "@angular/platform-browser": "^22.0.6",
    "@angular/router": "^22.0.6",
    "@codemirror/legacy-modes": "^6.5.3",
    "@primeuix/themes": "^2.0.3",
    "chart.js": "^4.5.1",
    "codemirror": "^6.0.2",
    "primeicons": "^7.0.0",
    "primeng": "^21.1.9",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular/build": "^22.0.6",
    "@angular/cli": "^22.0.6",
    "@angular/compiler-cli": "^22.0.6",
    "prettier": "^3.9.5",
    "typescript": "~6.0.3"
  }
}
